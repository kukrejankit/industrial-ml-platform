{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/*.js",
      "/*.css",
      "/*.ico",
      "/*.png",
      "/*.svg",
      "/*.woff",
      "/*.woff2",
      "/assets/*"
    ]
  },
  "globalHeaders": {
    "cache-control": "no-cache"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
